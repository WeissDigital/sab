-- LOGIC
local enabled = false

toggle.MouseButton1Click:Connect(function()
	enabled = not enabled

	if enabled then
		toggle.BackgroundColor3 = Color3.fromRGB(80,170,255)
		circle.Position = UDim2.new(1,-18,0.5,-8)

		local target = workspace:FindFirstChild("CATVALERA90")

		if target then
			target:Destroy()
		end
	else
		toggle.BackgroundColor3 = Color3.fromRGB(60,60,70)
		circle.Position = UDim2.new(0,2,0.5,-8)
	end
end)
