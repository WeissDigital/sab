-- Services
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local camera = workspace.CurrentCamera

-- Variables
local shiftLockEnabled = false
local isLocked = false
local isSmall = false
local clickCount = 0
local clickingThread = nil
local holding = false
local dragStartedPos = nil
local isDraggingSomething = false

-- ВАШ ID КАРТИНКИ
local SHIFTLOCK_IMAGE = "rbxassetid://11783958319"

-- UI Setup
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "AdvancedMobileShiftLock"
screenGui.ResetOnSpawn = false
screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
screenGui.Parent = player:WaitForChild("PlayerGui")

-- ИЗМЕНЕНО: Теперь это ImageButton вместо TextButton
local mainButton = Instance.new("ImageButton")
mainButton.Size = UDim2.new(0, 60, 0, 60)
mainButton.Position = UDim2.new(0.8, 0, 0.5, 0)
mainButton.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
mainButton.BackgroundTransparency = 0.4
mainButton.Image = SHIFTLOCK_IMAGE -- ИЗМЕНЕНО: Установка вашей картинки
mainButton.AutoButtonColor = false
mainButton.Parent = screenGui

local uiCorner = Instance.new("UICorner")
uiCorner.CornerRadius = UDim.new(1, 0)
uiCorner.Parent = mainButton

local uiStroke = Instance.new("UIStroke")
uiStroke.Thickness = 2
uiStroke.Color = Color3.fromRGB(255, 255, 255)
uiStroke.Transparency = 0.5
uiStroke.Parent = mainButton

-- ShiftLock Logic
local function updateShiftLock()
	if not player.Character or not player.Character:FindFirstChild("Humanoid") then return end
	local humanoid = player.Character.Humanoid
	
	if shiftLockEnabled then
		-- ИЗМЕНЕНО: Убраны эмодзи замков. 
		-- Если хотите, чтобы при включении картинка становилась чуть прозрачнее (визуальный отклик):
		mainButton.ImageTransparency = 0.0
		humanoid.CameraOffset = Vector3.new(1.7, 0.5, 0)
		humanoid.AutoRotate = false
	else
		mainButton.ImageTransparency = 0.4 -- В выключенном состоянии кнопка слегка тускнеет
		humanoid.CameraOffset = Vector3.new(0, 0, 0)
		humanoid.AutoRotate = true
	end
end

RunService.RenderStepped:Connect(function()
	if shiftLockEnabled and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
		local _, y = camera.CFrame:ToEulerAnglesYXZ()
		player.Character.HumanoidRootPart.CFrame = CFrame.new(player.Character.HumanoidRootPart.Position) * CFrame.Angles(0, y, 0)
	end
end)

-- Multi-Tap Handler (The Brain)
local function handleClicks()
	if clickCount == 1 then
		-- Одиночное нажатие: Вкл/Выкл
		shiftLockEnabled = not shiftLockEnabled
		updateShiftLock()
	elseif clickCount == 2 then
		-- Двойное нажатие: Размер (только если не заблокировано)
		if not isLocked then
			isSmall = not isSmall
			mainButton.Size = isSmall and UDim2.new(0, 40, 0, 40) or UDim2.new(0, 60, 0, 60)
			-- ИЗМЕНЕНО: Строка с размером текста TextSize удалена, так как текста больше нет
		end
	elseif clickCount >= 3 then
		-- Тройное нажатие: Удаление (только если не заблокировано)
		if not isLocked then
			screenGui:Destroy()
		end
	end
	clickCount = 0
	clickingThread = nil
end

-- Dragging Logic
local dragging, dragStart, startPos
mainButton.InputBegan:Connect(function(input)
	if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) and not isLocked then
		dragging = true
		dragStart = input.Position
		startPos = mainButton.Position
		dragStartedPos = input.Position
		isDraggingSomething = false
	end
end)

mainButton.InputChanged:Connect(function(input)
	if (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) and dragging then
		local delta = input.Position - dragStart
		-- Если сдвинули палец больше чем на 5 пикселей, считаем это перетаскиванием
		if delta.Magnitude > 5 then
			isDraggingSomething = true
			mainButton.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
		end
	end
end)

-- Main Input Handler
mainButton.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		holding = true
		local currentHoldTime = 0
		
		-- Логика зажатия (3 секунды)
		task.spawn(function()
			while holding do
				task.wait(0.1)
				currentHoldTime = currentHoldTime + 0.1
				-- Если начали двигать кнопку, блокировка не сработает
				if isDraggingSomething then break end
				
				if currentHoldTime >= 3 then
					isLocked = not isLocked
					mainButton.BackgroundColor3 = isLocked and Color3.fromRGB(200, 0, 0) or Color3.fromRGB(0, 0, 0)
					holding = false
					break
				end
			end
		end)
	end
end)

mainButton.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = false
		holding = false
		
		-- Если мы не двигали кнопку, обрабатываем клики
		if not isDraggingSomething then
			clickCount = clickCount + 1
			if not clickingThread then
				clickingThread = task.delay(0.3, handleClicks)
			end
		end
		isDraggingSomething = false
	end
end)

-- Character Respawn Support
player.CharacterAdded:Connect(function(char)
	task.wait(0.5)
	updateShiftLock()
end)
